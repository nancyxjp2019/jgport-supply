<view class="page-shell">
  <view class="hero-card">
    <view class="hero-title">{{heroTitle}}</view>
    <view class="hero-subtitle">{{heroSubtitle}}</view>
    <view class="button-row" style="margin-top: 18rpx;" wx:if="{{!financeWorkbench || role === 'CUSTOMER'}}">
      <view class="pill {{pendingOnly ? 'pill-active' : ''}}" wx:if="{{!financeWorkbench}}" bindtap="onTogglePending">仅看待处理</view>
      <button class="secondary-btn" wx:if="{{role === 'CUSTOMER'}}" bindtap="onCreate">新建订单</button>
    </view>
  </view>

  <view class="panel-card" wx:if="{{!financeWorkbench}}">
    <view class="section-title">状态筛选</view>
    <view class="section-row">
      <view
        class="pill {{currentStatus === item.value ? 'pill-active' : ''}}"
        wx:for="{{statusOptions}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onTapStatus"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-title">时间筛选</view>
    <view class="section-row">
      <view
        class="pill {{currentTimeFilter === item.value ? 'pill-active' : ''}}"
        wx:for="{{timeFilterOptions}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onPickTimeFilter"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="list-card" wx:if="{{items.length}}">
    <view class="list-item" wx:for="{{items}}" wx:key="id" data-id="{{item.id}}" bindtap="onOpenDetail">
      <view class="item-head">
        <view class="item-title">{{item.sales_order_no}}</view>
        <view class="item-tag">{{item.status_text}}</view>
      </view>
      <view class="item-meta">
        <view class="meta-line">日期 <text class="meta-strong">{{item.order_date_text}}</text></view>
        <view class="meta-line">仓库 <text class="meta-strong">{{item.warehouse_name}}</text></view>
        <view class="meta-line">油品 <text class="meta-strong">{{item.product_name}}</text></view>
        <view class="meta-line">数量 <text class="meta-strong">{{item.qty_text}} 吨</text></view>
        <view class="meta-line">合同 <text class="meta-strong">{{item.sales_contract_no}}</text></view>
        <view class="meta-line">金额 <text class="meta-strong">{{item.amount_text}} 元</text></view>
      </view>
    </view>
  </view>

  <view class="panel-card empty-card" wx:else>
    <view class="empty-text">{{loading ? '加载中...' : emptyText}}</view>
  </view>
</view>
