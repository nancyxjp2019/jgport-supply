.msg-hero-card {
  padding: 28rpx;
}

.todo-hero-meta {
  margin-top: 20rpx;
}

.status-card,
.empty-card {
  padding: 24rpx;
}

.status-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.error-card {
  border-color: rgba(250, 81, 81, 0.18);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 235, 238, 0.88));
}

.todo-summary-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.todo-summary-card {
  width: calc((100% - 16rpx) / 2);
  min-height: 184rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  color: #ffffff;
}

.todo-summary-card__label {
  font-size: 24rpx;
  opacity: 0.9;
}

.todo-summary-card__value {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
}

.todo-summary-card__desc {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  opacity: 0.88;
}

.todo-summary-card--normal,
.todo-summary-card--info {
  background: linear-gradient(160deg, #0f766e 0%, #0d9488 100%);
}

.todo-summary-card--warning {
  background: linear-gradient(160deg, #b45309 0%, #d97706 100%);
}

.todo-summary-card--danger {
  background: linear-gradient(160deg, #b91c1c 0%, #dc2626 100%);
}

.todo-summary-card--success {
  background: linear-gradient(160deg, #166534 0%, #15803d 100%);
}

.msg-tab-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.msg-tab {
  flex: 1;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(16, 174, 255, 0.08);
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
}

.msg-tab--active {
  background: linear-gradient(160deg, #0f766e 0%, #0d9488 100%);
  color: #ffffff;
}

.msg-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.msg-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid #e5eef0;
  box-shadow: 0 14rpx 30rpx rgba(15, 118, 110, 0.07);
}

.msg-card--read {
  opacity: 0.82;
}

.msg-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.msg-card__tags {
  flex: 1;
}

.msg-card__title {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #1f2937;
}

.msg-card__summary {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.7;
}

.msg-card__actions {
  margin-top: 20rpx;
}

.msg-card__btn {
  min-width: 200rpx;
}

.msg-level--danger {
  background: rgba(250, 81, 81, 0.12);
  color: #fa5151;
}

.msg-level--warning {
  background: rgba(255, 149, 0, 0.12);
  color: #ff9500;
}

.msg-level--success {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

.msg-level--info {
  background: rgba(16, 174, 255, 0.12);
  color: #10aeff;
}
