<view class="page-shell">
  <view class="hero-card">
    <view class="hero-title">采购订单</view>
    <view class="hero-subtitle">采购订单与销售订单一一对应，当前页面按 V5 正向流转展示。</view>
    <view class="button-row" style="margin-top: 18rpx;" wx:if="{{!financeWorkbench && !warehouseWorkbench}}">
      <view class="pill {{pendingOnly ? 'pill-active' : ''}}" bindtap="onTogglePending">仅看待处理</view>
    </view>
  </view>

  <view class="panel-card" wx:if="{{!financeWorkbench && !warehouseWorkbench}}">
    <view class="section-title">状态筛选</view>
    <view class="section-row">
      <view
        class="pill {{currentStatus === item.value ? 'pill-active' : ''}}"
        wx:for="{{statusOptions}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onTapStatus"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-title">时间筛选</view>
    <view class="section-row">
      <view
        class="pill {{currentTimeFilter === item.value ? 'pill-active' : ''}}"
        wx:for="{{timeFilterOptions}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onPickTimeFilter"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="list-card" wx:if="{{items.length}}">
    <view class="list-item" wx:for="{{items}}" wx:key="id" data-id="{{item.id}}" bindtap="onOpenDetail">
      <view class="item-head">
        <view class="item-title">{{item.purchase_order_no}}</view>
        <view class="item-tag">{{item.status_text}}</view>
      </view>
      <view class="item-meta">
        <view class="meta-line">销售单 <text class="meta-strong">{{item.sales_order_no}}</text></view>
        <view class="meta-line">供应商 <text class="meta-strong">{{item.supplier_company_name || '-'}}</text></view>
        <view class="meta-line">仓库 <text class="meta-strong">{{item.warehouse_name}}</text></view>
        <view class="meta-line">油品 <text class="meta-strong">{{item.product_name}}</text></view>
        <view class="meta-line">数量 <text class="meta-strong">{{item.qty_text}} 吨</text></view>
        <view class="meta-line">采购合同 <text class="meta-strong">{{item.purchase_contract_no || '-'}}</text></view>
      </view>
    </view>
  </view>

  <view class="panel-card empty-card" wx:else>
    <view class="empty-text">当前没有符合条件的采购订单</view>
  </view>
</view>
