.login-hero-card {
  padding: 28rpx;
}

.login-hero-meta {
  margin-top: 20rpx;
}

.mode-switch {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mode-btn {
  flex: 1;
  min-width: 200rpx;
  min-height: 76rpx;
  margin: 0;
  border-radius: 18rpx;
  background: rgba(16, 174, 255, 0.08);
  color: #10aeff;
  font-size: 26rpx;
  line-height: 76rpx;
}

.mode-btn::after {
  border: none;
}

.mode-btn--active {
  background: linear-gradient(160deg, #0f766e 0%, #0d9488 100%);
  color: #ffffff;
}

.mode-hint {
  margin-top: 16rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.7;
  word-break: break-all;
}

.binding-hint {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 243, 224, 0.88);
  border: 1rpx solid rgba(255, 149, 0, 0.18);
}

.binding-hint__title {
  color: #9a3412;
  font-size: 28rpx;
  font-weight: 700;
}

.binding-hint__desc,
.binding-hint__debug {
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.7;
  word-break: break-all;
}

.role-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-card {
  padding: 22rpx;
  border: 1rpx solid rgba(24, 50, 74, 0.12);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.84);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.role-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.role-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.role-card__desc,
.role-card__meta {
  color: #999999;
  font-size: 24rpx;
  line-height: 1.7;
}

.status-pill--allow {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

.status-pill--deny {
  background: rgba(255, 149, 0, 0.12);
  color: #ff9500;
}

.role-card .primary-btn {
  width: 100%;
}
