<view class="page-shell">
  <view class="hero-card login-hero-card">
    <view class="page-title">登录入口</view>
    <view class="page-subtitle">当前支持演示模式、本地联调和微信登录三种入口。按当前验证目标选择模式后继续。</view>
    <view class="pill-row login-hero-meta">
      <view class="version-pill">{{runtimeLabel}}</view>
      <view wx:if="{{currentRoleLabel}}" class="mode-pill">当前身份：{{currentRoleLabel}}</view>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-title">运行模式</view>
    <view class="section-desc">演示模式用于页面评审，本地联调用于开发者工具直连本机后端，微信登录用于验证真实 `wx.login` 链路。</view>
    <view class="mode-switch">
      <button class="mode-btn {{runtimeMode === 'demo' ? 'mode-btn--active' : ''}}" data-mode="demo" bindtap="onSelectMode">演示模式</button>
      <button class="mode-btn {{runtimeMode === 'local_api' ? 'mode-btn--active' : ''}}" data-mode="local_api" bindtap="onSelectMode">本地联调</button>
      <button class="mode-btn {{runtimeMode === 'wechat_auth' ? 'mode-btn--active' : ''}}" data-mode="wechat_auth" bindtap="onSelectMode">微信登录</button>
    </view>
    <view wx:if="{{runtimeMode === 'local_api' || runtimeMode === 'wechat_auth'}}" class="mode-hint">本机后端地址：{{apiBaseUrl}}</view>
  </view>

  <view class="panel-card" wx:if="{{runtimeMode !== 'wechat_auth'}}">
    <view class="section-title">选择角色</view>
    <view class="section-desc">运营、财务、管理员可查看经营快报；仓库可进入执行回执；客户、供应商用于验证当前已开放页面的中文阻断提示。</view>
    <view class="role-grid">
      <view wx:for="{{roleCards}}" wx:key="roleCode" class="role-card">
        <view>
          <view class="role-card__head">
            <view class="role-card__title">{{item.roleLabel}}</view>
            <view class="status-pill {{item.accessClass}}">{{item.accessText}}</view>
          </view>
          <view class="role-card__desc">{{item.description}}</view>
          <view class="role-card__meta">{{item.companyLabel}}</view>
        </view>
        <button class="primary-btn" data-role-code="{{item.roleCode}}" bindtap="onLogin">以该角色进入</button>
      </view>
    </view>
  </view>

  <view class="panel-card" wx:if="{{runtimeMode === 'wechat_auth'}}">
    <view class="section-title">微信登录</view>
    <view class="section-desc">该模式通过微信官方 `wx.login` 获取临时凭证，再由后端调用 `code2session` 完成身份识别。</view>
    <button class="primary-btn" bindtap="onLogin">使用微信身份登录</button>
    <view wx:if="{{bindingHint}}" class="binding-hint">
      <view class="binding-hint__title">当前微信账号尚未完成绑定</view>
      <view class="binding-hint__desc">{{bindingHint}}</view>
      <view wx:if="{{debugOpenId}}" class="binding-hint__debug">开发环境 openid：{{debugOpenId}}</view>
    </view>
  </view>

  <view class="panel-card" wx:if="{{currentRoleLabel}}">
    <view class="section-title">当前会话</view>
    <view class="section-desc">当前已选择 <text class="meta-strong">{{currentRoleLabel}}</text> 身份，运行模式为 <text class="meta-strong">{{runtimeLabel}}</text>。</view>
    <view class="button-row" style="margin-top: 20rpx;">
      <button class="secondary-btn" bindtap="onEnterReport">{{currentHomeLabel}}</button>
      <button class="danger-btn" bindtap="onLogout">清除当前身份</button>
    </view>
  </view>
</view>
