.exec-hero-card {
  padding: 28rpx;
}

.exec-hero-meta {
  margin-top: 20rpx;
}

.field-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.field-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #333333;
}

.field-required {
  margin-right: 8rpx;
  color: #fa5151;
}

.field-input,
.field-textarea {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  border: 1rpx solid #eeeeee;
  background: rgba(255, 255, 255, 0.92);
  color: #333333;
  font-size: 28rpx;
  line-height: 88rpx;
}

.field-textarea {
  min-height: 156rpx;
  padding: 20rpx 24rpx;
  line-height: 1.7;
}

.field-error {
  color: #fa5151;
  font-size: 22rpx;
  line-height: 1.6;
}

.inline-error-card {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(250, 81, 81, 0.16);
  background: rgba(255, 235, 238, 0.72);
}

.result-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(232, 245, 233, 0.82));
}

.result-pill-row {
  margin-top: 16rpx;
}

.result-list,
.hint-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 20rpx;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.result-row:last-child {
  border-bottom: none;
}

.result-row__label {
  color: #999999;
  font-size: 24rpx;
}

.result-row__value {
  color: #333333;
  font-size: 26rpx;
  font-weight: 700;
  text-align: right;
  word-break: break-all;
}

.hint-item {
  color: #666666;
  font-size: 24rpx;
  line-height: 1.8;
}
