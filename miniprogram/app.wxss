page {
  min-height: 100%;
  background:
    radial-gradient(circle at top right, rgba(205, 224, 244, 0.92), transparent 36%),
    linear-gradient(180deg, #f7f2e8 0%, #f4efe5 48%, #efe7db 100%);
  color: #18324a;
  font-size: 28rpx;
}

view,
text,
button,
input,
picker,
textarea {
  box-sizing: border-box;
}

:root {
  --brand-deep: #0d3b66;
  --brand-ink: #18324a;
  --brand-accent: #c1662b;
  --brand-warm: #f1e6d3;
  --surface-strong: rgba(255, 252, 246, 0.92);
  --surface-soft: rgba(255, 250, 242, 0.74);
  --border-soft: rgba(24, 50, 74, 0.12);
  --danger: #af3b2f;
  --success: #2d6a4f;
  --muted: #6b7d8d;
}

.page-shell {
  padding: 28rpx 24rpx 40rpx;
}

.hero-card,
.panel-card,
.list-card,
.form-card,
.action-card {
  background: var(--surface-strong);
  border: 1rpx solid var(--border-soft);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(13, 59, 102, 0.08);
}

.hero-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.panel-card,
.list-card,
.form-card,
.action-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.hero-title,
.section-title,
.card-title {
  color: var(--brand-deep);
  font-weight: 700;
}

.hero-title {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.hero-subtitle,
.section-desc,
.muted-text,
.empty-text {
  color: var(--muted);
}

.hero-subtitle,
.section-desc,
.muted-text {
  font-size: 24rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 30rpx;
  margin-bottom: 16rpx;
}

.section-row,
.inline-row,
.button-row {
  display: flex;
  align-items: center;
}

.section-row,
.button-row {
  gap: 16rpx;
  flex-wrap: wrap;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(13, 59, 102, 0.08);
  color: var(--brand-deep);
  font-size: 22rpx;
}

.pill-active {
  background: var(--brand-deep);
  color: #fff;
}

.grid-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.action-tile {
  min-height: 150rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(160deg, rgba(13, 59, 102, 0.96), rgba(27, 77, 131, 0.92));
  color: #f7f2e8;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.action-tile-warm {
  background: linear-gradient(160deg, rgba(193, 102, 43, 0.96), rgba(154, 68, 24, 0.9));
}

.action-tile-title {
  font-size: 30rpx;
  font-weight: 700;
}

.action-tile-desc {
  font-size: 22rpx;
  line-height: 1.6;
  opacity: 0.86;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--brand-ink);
  font-size: 24rpx;
  font-weight: 600;
}

.field-required {
  color: var(--danger);
  margin-right: 6rpx;
}

.field-optional {
  color: var(--muted);
  font-weight: 400;
}

.field-value,
.field-input,
.field-picker,
.field-textarea {
  width: 100%;
  min-height: 84rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(24, 50, 74, 0.14);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.86);
  color: var(--brand-ink);
}

.field-textarea {
  min-height: 180rpx;
}

.field-static {
  min-height: 84rpx;
  padding: 22rpx 0 8rpx;
  color: var(--brand-ink);
}

.field-block {
  margin-bottom: 20rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  min-width: 200rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 84rpx;
}

.primary-btn {
  background: var(--brand-deep);
  color: #fff;
}

.secondary-btn {
  background: rgba(13, 59, 102, 0.08);
  color: var(--brand-deep);
}

.danger-btn {
  background: rgba(175, 59, 47, 0.12);
  color: var(--danger);
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(24, 50, 74, 0.08);
}

.list-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.item-title {
  color: var(--brand-deep);
  font-size: 30rpx;
  font-weight: 700;
}

.item-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(13, 59, 102, 0.08);
  color: var(--brand-deep);
  font-size: 22rpx;
  white-space: nowrap;
}

.item-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx 18rpx;
}

.meta-line {
  color: var(--muted);
  font-size: 23rpx;
  line-height: 1.6;
}

.meta-strong {
  color: var(--brand-ink);
}

.empty-card {
  padding: 54rpx 26rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
}

.footer-safe {
  height: 24rpx;
}
