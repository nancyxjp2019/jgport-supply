app_name=JGSDSC Supply Chain API
env=dev
debug=true
api_prefix=/api/v1

database_url=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/jgsd_supply_chain

jwt_secret_key=please-change-this-in-production
jwt_algorithm=HS256
jwt_expire_minutes=120

activation_code_expire_minutes=1440
activation_link_base_url=https://your-domain.com/activate
wechat_login_mode=mock
wechat_app_id=your-wechat-app-id
wechat_app_secret=your-wechat-app-secret
wechat_api_base=https://api.weixin.qq.com
wechat_api_timeout_seconds=8

file_storage_backend=local
local_upload_dir=./uploads
local_upload_base_url=/media
upload_max_size_mb=20
oss_bucket_name=
oss_endpoint=
oss_access_key_id=
oss_access_key_secret=
oss_base_url=
oss_prefix=attachments

log_dir=./logs
log_level=INFO
log_retention_days=30
